# Neon development branch connection string used by Prisma CLI and the app runtime.
DATABASE_URL="postgresql://USER:PASSWORD@HOST/devstash_dev?sslmode=require"

# Optional: only needed if your database user cannot create the shadow database
# during `prisma migrate dev`.
# SHADOW_DATABASE_URL="postgresql://USER:PASSWORD@HOST/devstash_shadow?sslmode=require"

# Auth.js
AUTH_SECRET="replace-with-a-long-random-string"
AUTH_GITHUB_ID="your-github-oauth-app-id"
AUTH_GITHUB_SECRET="your-github-oauth-app-secret"
RESEND_API_KEY="resend-api-key"
